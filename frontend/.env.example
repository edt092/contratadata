# Copiar a .env.local y completar con valores reales. Nunca versionar .env.local.

# URL base de la API FastAPI
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Auth0 (ver auth.md y docs/auth0-setup.md) — SDK @auth0/nextjs-auth0.
# AUTH0_SECRET: cualquier string aleatorio largo, usado para encriptar la
# cookie de sesión. Generar con: openssl rand -hex 32
AUTH0_SECRET=
AUTH0_BASE_URL=http://localhost:3000
# https://{tu-tenant}.us.auth0.com (o el dominio custom del tenant)
AUTH0_ISSUER_BASE_URL=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
# Identifier de la API creada en Auth0 (Applications → APIs) — debe ser el
# mismo valor que AUTH0_AUDIENCE en el .env del backend.
AUTH0_AUDIENCE=
