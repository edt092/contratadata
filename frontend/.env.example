# Copiar a .env.local y completar con valores reales. Nunca versionar .env.local.

# URL base de la API FastAPI
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Clerk (ver auth2.md y docs/clerk-setup.md) — SDK @clerk/nextjs.
# Clerk Dashboard → API Keys (instancia Development o Production según el
# entorno que estés corriendo).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Rutas de las páginas propias de sign-in/sign-up (ver
# frontend/app/sign-in, frontend/app/sign-up) — evita que componentes de
# Clerk redirijan al Account Portal hospedado por default.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
