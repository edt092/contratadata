# Copiar a .env y completar con valores reales. Nunca versionar .env.

# Base de datos
POSTGRES_DB=contratadb
POSTGRES_USER=contratauser
POSTGRES_PASSWORD=contratapass

# Usuario de solo lectura para el dashboard
POSTGRES_READONLY_USER=contrataread
POSTGRES_READONLY_PASSWORD=contratareadpass

# URL de conexión completa (usada por el ETL)
DATABASE_URL=postgresql://contratauser:contratapass@db:5432/contratadb

# Token de aplicación Socrata (opcional pero recomendado para mayor cuota)
# Registrar en: https://data.socrata.com/profile/edit/developer_settings
SOCRATA_APP_TOKEN=

# Nivel de logging: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Notificación de feedback de usuarios (src/notify.py). Sin SMTP_HOST, el
# feedback igual se guarda en la BD — solo se loguea en vez de enviar email.
FEEDBACK_NOTIFY_EMAIL=feedback@contratadata.xyz
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Clerk (ver auth2.md y docs/clerk-setup.md) — validación de session tokens
# en FastAPI + sincronización de perfil + webhooks de identidad.
# CLERK_SECRET_KEY: Clerk Dashboard → API Keys (instancia Development o
# Production según el entorno) — nunca la publishable key acá.
CLERK_SECRET_KEY=
# CLERK_JWKS_URL: Frontend API de la instancia + /.well-known/jwks.json
# (ej. https://xxx.clerk.accounts.dev/.well-known/jwks.json en dev, o el
# dominio custom en producción) — público, ver Clerk Dashboard → API Keys →
# "Show JWKS URL".
CLERK_JWKS_URL=
# Issuer = la misma Frontend API, sin el sufijo /.well-known/jwks.json.
CLERK_ISSUER=
CLERK_ALGORITHMS=RS256
# Lista explícita (coma-separada) de orígenes autorizados a generar tokens —
# valida el claim 'azp'. Incluir todos los dominios del frontend (local +
# producción).
CLERK_AUTHORIZED_PARTIES=http://localhost:3000,https://contratadata.xyz
# Signing secret del webhook endpoint (Clerk Dashboard → Webhooks → tu
# endpoint → Signing Secret, empieza con whsec_).
CLERK_WEBHOOK_SECRET=

# Wompi (ver auth.md y API-WOMPI-CONTRATADATA.txt) — checkout y webhook de
# eventos para activar el plan Pro. Llaves reales solo en las variables de
# entorno de Railway, nunca en este archivo ni versionadas.
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_INTEGRITY_SECRET=
WOMPI_EVENTS_SECRET=
# Dominio del frontend, usado para construir la redirect_url del checkout.
FRONTEND_BASE_URL=https://contratadata.xyz
